{
  "dashboard": {
    "title": "Smart Debug Console - Simple",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Logs Processed per Minute",
        "type": "timeseries",
        "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(logs_processed_total[1m]) * 60",
            "legendFormat": "{{severity}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Total Logs by Severity",
        "type": "stat",
        "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "logs_processed_total",
            "legendFormat": "{{severity}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "ML Predictions per Minute",
        "type": "timeseries",
        "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
        "targets": [
          {
            "expr": "rate(ml_predictions_total[1m]) * 60",
            "legendFormat": "{{severity}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Active WebSocket Connections",
        "type": "gauge",
        "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
        "targets": [
          {
            "expr": "websocket_connections_active",
            "refId": "A"
          }
        ]
      }
    ],
    "refresh": "5s",
    "time": {
      "from": "now-5m",
      "to": "now"
    }
  },
  "overwrite": true
}